<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Signup</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
<form method="post" action="/signUp">
<div class="container d-flex justify-content-center align-items-center vh-100">
  <div class="card p-4 shadow" style="width: 400px;">
    <h3 class="text-center mb-3">Create Account</h3>

    <input name="name" type="text" class="form-control mb-2" placeholder="Full Name">
    <input name="username" type="text" class="form-control mb-2" placeholder="Username">
    <input name="email" type="email" class="form-control mb-2" placeholder="Email">
    <input name="password" type="password" class="form-control mb-3" placeholder="Password">

    <button class="btn btn-success w-100" type="submit">Sign Up</button>
    <form method="get">
    <p class="text-center mt-3">
      Already have an account? <a href="/">Login</a>
    </p>
    </form>
  </div>
</div>

</form>
</body>
</html>